<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1A1A2E">

    <!-- Decorative Glow -->
    <View
        android:layout_width="400dp"
        android:layout_height="400dp"
        android:layout_centerInParent="true"
        android:background="@android:drawable/presence_online"
        android:alpha="0.05"
        android:backgroundTint="#E94560" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <ImageView
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:src="@android:drawable/ic_lock_lock"
            android:contentDescription="Locked"
            android:tint="#E94560" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="LOCKDOWN ACTIVE"
            android:textColor="#E94560"
            android:textSize="14sp"
            android:letterSpacing="0.2"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/timerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="25:00"
            android:textColor="#FFFFFF"
            android:textSize="80sp"
            android:fontFamily="sans-serif-condensed-light" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="REMAINING FOCUS TIME"
            android:textColor="#4E4E6A"
            android:textSize="12sp"
            android:letterSpacing="0.1" />

        <View
            android:layout_width="40dp"
            android:layout_height="2dp"
            android:layout_marginTop="48dp"
            android:background="#E94560" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:gravity="center"
            android:text="Your phone is a tool, not a trap.\nFinish what you started."
            android:textColor="#99FFFFFF"
            android:textSize="16sp"
            android:lineSpacingExtra="6dp" />

    </LinearLayout>

    <Button
        android:id="@+id/callButton"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="40dp"
        android:backgroundTint="#16213E"
        android:text="EMERGENCY CALL"
        android:letterSpacing="0.1"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:elevation="0dp" />

</RelativeLayout>
