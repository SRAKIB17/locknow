<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#0F0C29">

    <!-- Deep Background Glow -->
    <View
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@android:drawable/screen_background_dark_transparent"
        android:alpha="0.2" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="40dp">

        <ImageView
            android:layout_width="72dp"
            android:layout_height="72dp"
            android:src="@android:drawable/ic_lock_lock"
            android:contentDescription="Strictly Locked"
            android:tint="#E94560" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:text="ULTRA FOCUS MODE ACTIVE"
            android:textColor="#E94560"
            android:textSize="12sp"
            android:letterSpacing="0.3"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/timerTextView"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="25:00"
            android:textColor="#FFFFFF"
            android:textSize="90sp"
            android:fontFamily="sans-serif-thin" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="REMAINING TIME"
            android:textColor="#4E4E6A"
            android:textSize="11sp"
            android:letterSpacing="0.2" />

        <View
            android:layout_width="60dp"
            android:layout_height="1dp"
            android:layout_marginTop="56dp"
            android:background="#E94560" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="40dp"
            android:gravity="center"
            android:text="System Access is restricted.\nYour dopamine loop is broken."
            android:textColor="#B0B0C0"
            android:textSize="15sp"
            android:lineSpacingExtra="8dp" />

    </LinearLayout>

    <Button
        android:id="@+id/callButton"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:layout_alignParentBottom="true"
        android:layout_margin="32dp"
        android:backgroundTint="#E94560"
        android:text="EMERGENCY CALL"
        android:letterSpacing="0.15"
        android:textColor="#FFFFFF"
        android:textSize="14sp"
        android:textStyle="bold"
        android:elevation="8dp" />

</RelativeLayout>
